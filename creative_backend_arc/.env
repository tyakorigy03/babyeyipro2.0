# ─────────────────────────────────────────────
#  SERVER
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────
#  DATABASE  (MySQL via Sequelize)
# ─────────────────────────────────────────────
DB_NAME=babyeyipro2
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_DIALECT=mysql

# ─────────────────────────────────────────────
#  JWT
# ─────────────────────────────────────────────
JWT_SECRET=babyeyi_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
#  EMAIL  (Nodemailer – Gmail example)
# ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
